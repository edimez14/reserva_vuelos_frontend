# .env.example — Variables de entorno requeridas por el frontend
#
# Copia este archivo como .env.local para desarrollo local:
#   cp .env.example .env.local
#
# En Vercel, añade estas variables en:
#   Dashboard → Project → Settings → Environment Variables
# ---------------------------------------------------------------

# URL del backend (Django + Gunicorn en Fly.io).
# Desarrollo local: http://localhost:8000/api/v1
# Producción: https://<tu-app>.fly.dev/api/v1
NEXT_PUBLIC_API_URL=https://<tu-app>.fly.dev/api/v1
